---
interface Props {
  items: { question: string; answer: string }[];
}

const { items } = Astro.props;
---

<div class="space-y-4">
  {items.map((item, index) => (
    <details
      class="group bg-surface-container-lowest rounded-xl border border-outline-variant/20 overflow-hidden"
      name="faq"
    >
      <summary class="flex items-center justify-between p-5 cursor-pointer font-display text-headline-sm font-semibold text-on-surface list-none hover:bg-surface-container-low transition-colors">
        <span>{item.question}</span>
        <span class="ml-4 text-primary transition-transform duration-200 group-open:rotate-180">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m6 9 6 6 6-6" />
          </svg>
        </span>
      </summary>
      <div class="px-5 pb-5 text-body-md text-on-surface-variant leading-relaxed">
        {item.answer}
      </div>
    </details>
  ))}
</div>
