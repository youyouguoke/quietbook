---
import type { CollectionEntry } from "astro:content";
import Button from "../common/Button.astro";
import Badge from "../common/Badge.astro";

interface Props {
  book: CollectionEntry<"books">;
}

const { book } = Astro.props;
const data = book.data;
---

<div class="flex flex-col gap-5">
  <div class="flex flex-wrap gap-2">
    <Badge variant="secondary">New Release</Badge>
    <Badge variant="outline">Free PDF</Badge>
  </div>

  <h1 class="font-display text-3xl md:text-4xl font-bold text-text">{data.title}</h1>
  <p class="text-lg text-text-muted">{data.description}</p>

  <Button type="primary" href={data.pdf || "#"}>
    <span class="material-symbols-outlined">download</span>
    Download Free PDF
  </Button>
</div>
