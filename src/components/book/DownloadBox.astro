---
interface Props {
  href: string;
}

const { href } = Astro.props;
---

<a
  href={href}
  class="w-full py-4 bg-brand text-white rounded-soft font-medium hover:bg-brand-dark transition-all flex items-center justify-center gap-2"
>
  <span class="material-symbols-outlined">download</span>
  Download Free PDF
</a>
