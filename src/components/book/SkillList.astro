---
interface Skill {
  name: string;
  description: string;
  icon: string;
}

interface Props {
  skills: Skill[];
}

const { skills } = Astro.props;
---

<div class="grid grid-cols-1 md:grid-cols-3 gap-12">
  {skills.map((s) => (
    <div class="text-center">
      <span class="material-symbols-outlined text-6xl mb-4 text-brand-light">{s.icon}</span>
      <h4 class="font-display text-lg font-semibold text-white mb-2">{s.name}</h4>
      <p class="text-white/80">{s.description}</p>
    </div>
  ))}
</div>
