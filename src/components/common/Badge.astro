---
interface Props {
  children: any;
  variant?: "default" | "secondary" | "outline";
}

const { variant = "default" } = Astro.props;

const base = "inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold tracking-wide";
const variants = {
  default: "bg-brand-light text-brand-dark",
  secondary: "bg-cream text-text",
  outline: "border border-brand/30 text-brand-dark",
};
---

<span class:list={[base, variants[variant]]}>
  <slot />
</span>
