---
interface Props {
  type: "primary" | "secondary";
  href?: string;
  class?: string;
}

const { type = "primary", href, class: className = "" } = Astro.props;

const base = "inline-flex items-center justify-center rounded-full px-6 py-3 font-medium transition-all";
const styles = {
  primary: "bg-brand text-white hover:bg-brand-dark",
  secondary: "bg-brand-light text-brand-dark hover:bg-sand",
};
---

{
  href ? (
    <a href={href} class:list={[base, styles[type], className]}>
      <slot />
    </a>
  ) : (
    <button class:list={[base, styles[type], className]}>
      <slot />
    </button>
  )
}
