---
interface Props {
  title: string;
  difficulty: string;
  skills: string[];
  pages: number;
  cover: string;
  slug: string;
  description?: string;
}

const { title, difficulty, skills, pages, cover, slug, description } = Astro.props;

const difficultyColors: Record<string, string> = {
  Easy: "bg-primary-container text-on-primary-container",
  Medium: "bg-tertiary-container text-on-tertiary-container",
  Advanced: "bg-secondary-container text-on-secondary-container",
};
---

<a
  href={`/quiet-book/${slug}`}
  class="group block bg-surface-container-lowest rounded-xl overflow-hidden transition-transform duration-300 hover:-translate-y-2 soft-bloom"
>
  <div class="relative aspect-[4/5] bg-surface-container-low">
    <img
      src={cover}
      alt={`${title} cover`}
      class="w-full h-full object-cover"
      loading="lazy"
      decoding="async"
      onerror="this.src='/images/placeholder.webp'"
    />
    <div class="absolute top-4 left-4">
      <span class:list={["px-3 py-1 rounded-full text-label-sm font-label-sm", difficultyColors[difficulty] || "bg-primary-container text-on-primary-container"]}>
        {difficulty}
      </span>
    </div>
  </div>

  <div class="p-6">
    <h3 class="font-display text-headline-md text-on-surface mb-2">
      {title}
    </h3>

    <div class="flex flex-wrap gap-2 mb-4">
      {skills.slice(0, 3).map((skill) => (
        <span class="bg-secondary-container/30 text-on-secondary-container px-2 py-0.5 rounded-md text-label-sm font-label-sm">
          {skill}
        </span>
      ))}
    </div>

    <p class="text-on-surface-variant text-body-md line-clamp-2 mb-4">
      {description || `A printable ${title.toLowerCase()} quiet book for hands-on learning.`}
    </p>

    <div class="flex items-center justify-between mt-auto">
      <span class="text-label-sm text-on-surface-variant">{pages} Pages</span>
      <span class="bg-primary text-on-primary px-4 py-2 rounded-lg font-label-md text-label-md hover:opacity-90 transition-opacity">
        View Book
      </span>
    </div>
  </div>
</a>
