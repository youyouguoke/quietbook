---
const navItems = [
  { label: "Library", href: "/quiet-books" },
  { label: "Educators", href: "/for-educators" },
  { label: "How it Works", href: "#how-it-works" },
  { label: "About", href: "/about" },
];

const mobileNavItems = [
  { icon: "home", label: "Home", href: "/" },
  { icon: "local_library", label: "Library", href: "/quiet-books" },
  { icon: "school", label: "Learn", href: "/blog" },
  { icon: "bookmark", label: "Saved", href: "#" },
];
---

<header class="sticky top-0 z-50 bg-surface">
  <nav class="container-main flex items-center justify-between h-20">
    <a href="/" class="flex items-center gap-3">
      <img src="/images/logo.jpg" alt="Quiet Library" class="h-10 w-10 rounded-lg" />
      <span class="font-display text-headline-md font-semibold text-primary">Quiet Library</span>
    </a>

    <div class="hidden md:flex gap-8 items-center">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="font-label-md text-label-md font-medium text-on-surface-variant hover:text-primary transition-colors duration-200"
        >
          {item.label}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-4">
      <a href="#" class="hidden md:block font-label-md text-label-md font-semibold text-primary active:opacity-80 active:scale-95 transition-all">Sign In</a>
      <a href="/quiet-books" class="bg-primary text-on-primary px-6 py-2.5 rounded-lg font-label-md text-label-md shadow-sm hover:bg-primary-container hover:text-on-primary-container transition-all active:scale-95">
        Get Started
      </a>

      <button
        class="md:hidden w-10 h-10 rounded-full border border-outline-variant flex items-center justify-center text-on-surface-variant hover:text-primary hover:border-primary transition-colors"
        aria-label="Open menu"
        id="menu-toggle"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" y1="8" x2="20" y2="8"></line>
          <line x1="4" y1="16" x2="20" y2="16"></line>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-outline-variant/30 bg-surface-container-low">
    <nav class="container-main py-4 flex flex-col gap-3">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="text-on-surface-variant hover:text-primary font-label-md text-label-md py-2 transition-colors"
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>

  <!-- Mobile Bottom Nav -->
  <nav class="fixed bottom-0 w-full z-50 flex justify-around items-center px-margin-mobile py-3 md:hidden bg-surface-container-low shadow-[0_-4px_20px_rgba(0,0,0,0.05)] rounded-t-xl">
    {mobileNavItems.map((item, index) => (
      <a
        href={item.href}
        class:list={[
          "flex flex-col items-center justify-center rounded-full px-4 py-1 transition-all active:scale-90",
          index === 0 ? "bg-primary-container text-on-primary-container" : "text-on-surface-variant hover:bg-surface-variant",
        ]}
      >
        <span class="material-symbols-outlined">{item.icon}</span>
        <span class="font-label-sm text-[10px] uppercase">{item.label}</span>
      </a>
    ))}
  </nav>

  <script>
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    if (toggle && menu) {
      toggle.addEventListener('click', () => {
        menu.classList.toggle('hidden');
      });
    }
  </script>
</header>
