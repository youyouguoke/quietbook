---
const navItems = [
  { label: "Quiet Books", href: "/quiet-books" },
  { label: "Categories", href: "/categories" },
  { label: "Skills", href: "/skills" },
  { label: "Blog", href: "/blog" },
  { label: "About", href: "/about" },
];
---

<header class="sticky top-0 z-50 bg-surface-container-lowest/80 backdrop-blur border-b border-outline-variant/30">
  <div class="container-main flex items-center justify-between h-16 md:h-20">
    <a href="/" class="font-display text-headline-md md:text-headline-lg font-bold text-primary tracking-tight">
      Quiet Book Library
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="text-on-surface-variant hover:text-primary font-body-md transition-colors"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a
        href="/search"
        class="w-10 h-10 rounded-full border border-outline-variant flex items-center justify-center text-on-surface-variant hover:text-primary hover:border-primary transition-colors"
        aria-label="Search"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
      </a>

      <button
        class="md:hidden w-10 h-10 rounded-full border border-outline-variant flex items-center justify-center text-on-surface-variant hover:text-primary hover:border-primary transition-colors"
        aria-label="Open menu"
        id="menu-toggle"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" y1="8" x2="20" y2="8"></line>
          <line x1="4" y1="16" x2="20" y2="16"></line>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-outline-variant/30 bg-surface-container-lowest">
    <nav class="container-main py-4 flex flex-col gap-3">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="text-on-surface-variant hover:text-primary font-body-md py-2 transition-colors"
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>

  <script>
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    if (toggle && menu) {
      toggle.addEventListener('click', () => {
        menu.classList.toggle('hidden');
      });
    }
  </script>
</header>
