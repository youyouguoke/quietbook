---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SectionHeader from "../components/SectionHeader.astro";
import BookCard from "../components/BookCard.astro";

const skillFiles = import.meta.glob("../content/skills/*.md", { eager: true });
const bookFiles = import.meta.glob("../content/books/*.md", { eager: true });
const books = Object.values(bookFiles).map((b: any) => b.frontmatter);

const skills = Object.values(skillFiles).map((skill: any) => ({
  name: skill.frontmatter.name,
  slug: skill.frontmatter.slug,
  description: skill.frontmatter.description,
  bookSlugs: skill.frontmatter.books || [],
}));
---

<Layout
  title="Quiet Books by Skill"
  description="Find quiet books that develop specific skills: fine motor, matching, logic, creativity and learning."
>
  <Header />

  <main class="bg-surface pt-8 pb-20">
    <section class="container-main">
      <div class="py-12 md:py-16 text-center">
        <h1 class="font-display text-headline-lg-mobile md:text-headline-lg font-bold text-on-surface">Skills</h1>
        <p class="text-body-lg text-on-surface-variant mt-4 max-w-2xl mx-auto">
          Choose quiet books by the skills you want to develop. Each book targets learning through hands-on play.
        </p>
      </div>

      <div class="space-y-16">
        {skills.map((skill) => {
          const relatedBooks = books.filter((b: any) => skill.bookSlugs.includes(b.slug));
          return (
            <div class="border-b border-outline-variant/30 pb-12">
              <div class="mb-6">
                <h2 class="font-display text-headline-md font-bold text-on-surface">
                  <a href={`/${skill.slug}-quiet-books`} class="hover:text-primary transition-colors">
                    {skill.name}
                  </a>
                </h2>
                <p class="text-body-md text-on-surface-variant mt-2 max-w-2xl">{skill.description}</p>
              </div>

              {relatedBooks.length > 0 ? (
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                  {relatedBooks.map((book: any) => (
                    <BookCard
                      title={book.title}
                      slug={book.slug}
                      difficulty={book.difficulty}
                      skills={book.skills}
                      pages={book.pages}
                      cover={book.cover}
                    />
                  ))}
                </div>
              ) : (
                <p class="text-body-md text-on-surface-variant">Books coming soon for this skill.</p>
              )}
            </div>
          );
        })}
      </div>
    </section>
  </main>

  <Footer />
</Layout>
