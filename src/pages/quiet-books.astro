---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import BookCard from "../components/BookCard.astro";

const bookFiles = import.meta.glob("../content/books/*.md", { eager: true });
const books = Object.values(bookFiles).map((book: any) => ({
  title: book.frontmatter.title,
  slug: book.frontmatter.slug,
  difficulty: book.frontmatter.difficulty,
  skills: book.frontmatter.skills,
  pages: book.frontmatter.pages,
  cover: book.frontmatter.cover,
  description: book.frontmatter.description,
}));

const themes = [...new Set(books.map((b) => b.theme || 'General'))];
const difficulties = [...new Set(books.map((b) => b.difficulty))];
const allSkills = [...new Set(books.flatMap((b) => b.skills))];
---

<Layout
  title="Quiet Books | Scandinavian Montessori Principles"
  description="Explore printable activity books for creative learning and independent play. Designed with Scandinavian simplicity to foster focus and wonder."
>
  <Header />

  <main class="min-h-screen">
    <!-- Hero Section -->
    <section class="pt-section-gap pb-12 container-main text-center">
      <h1 class="font-display text-display-lg text-on-surface mb-4">Quiet Books</h1>
      <p class="font-body text-body-lg text-on-surface-variant max-w-2xl mx-auto">
        Explore printable activity books for creative learning and independent play. Designed with Scandinavian simplicity to foster focus and wonder.
      </p>
    </section>

    <!-- Filter Toolbar -->
    <section class="sticky top-20 z-40 bg-background/80 backdrop-blur-md pb-8">
      <div class="container-main">
        <div class="bg-surface-container-low rounded-xl p-4 flex flex-wrap items-center gap-4 soft-bloom">
          <div class="flex flex-col gap-1 flex-1 min-w-[150px]">
            <label class="text-label-sm text-on-surface-variant px-1">Theme</label>
            <select id="theme-filter" class="bg-surface-container border-none rounded-lg text-label-md focus:ring-2 focus:ring-primary outline-none py-2 px-3">
              <option value="">All Themes</option>
              {themes.map((t) => (
                <option value={t}>{t}</option>
              ))}
            </select>
          </div>

          <div class="flex flex-col gap-1 flex-1 min-w-[150px]">
            <label class="text-label-sm text-on-surface-variant px-1">Difficulty</label>
            <select id="difficulty-filter" class="bg-surface-container border-none rounded-lg text-label-md focus:ring-2 focus:ring-primary outline-none py-2 px-3">
              <option value="">Any Level</option>
              {difficulties.map((d) => (
                <option value={d}>{d}</option>
              ))}
            </select>
          </div>

          <div class="flex flex-col gap-1 flex-1 min-w-[150px]">
            <label class="text-label-sm text-on-surface-variant px-1">Skill Focus</label>
            <select id="skill-filter" class="bg-surface-container border-none rounded-lg text-label-md focus:ring-2 focus:ring-primary outline-none py-2 px-3">
              <option value="">All Skills</option>
              {allSkills.map((s) => (
                <option value={s}>{s}</option>
              ))}
            </select>
          </div>

          <div class="flex flex-col gap-1 flex-[1.5] min-w-[200px] relative justify-end">
            <label class="text-label-sm text-on-surface-variant px-1">Search</label>
            <div class="relative">
              <input
                id="search-input"
                type="text"
                placeholder="Search quiet books..."
                class="w-full bg-surface-container border-none rounded-lg pl-10 pr-4 py-2 text-label-md focus:ring-2 focus:ring-primary outline-none"
              />
              <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant">search</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Main Content: Bento Grid Layout -->
    <section class="container-main pb-section-gap">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-gutter" id="book-grid">
        {books.map((book) => (
          <div
            class="book-item"
            data-theme={book.theme || 'General'}
            data-difficulty={book.difficulty}
            data-skills={book.skills.join(",")}
            data-title={book.title}
            data-description={book.description || ""}
          >
            <BookCard {...book} />
          </div>
        ))}
      </div>
    </section>
  </main>

  <Footer />

  <script>
    const themeFilter = document.getElementById('theme-filter');
    const difficultyFilter = document.getElementById('difficulty-filter');
    const skillFilter = document.getElementById('skill-filter');
    const searchInput = document.getElementById('search-input');
    const items = document.querySelectorAll('.book-item');

    function filter() {
      const theme = themeFilter?.value || '';
      const difficulty = difficultyFilter?.value || '';
      const skill = skillFilter?.value || '';
      const query = searchInput?.value.toLowerCase().trim() || '';

      items.forEach((item) => {
        const t = item.getAttribute('data-theme') || '';
        const d = item.getAttribute('data-difficulty') || '';
        const s = item.getAttribute('data-skills') || '';
        const title = item.getAttribute('data-title') || '';
        const desc = item.getAttribute('data-description') || '';
        const text = (title + ' ' + desc).toLowerCase();
        const matchTheme = !theme || t === theme;
        const matchDifficulty = !difficulty || d === difficulty;
        const matchSkill = !skill || s.split(',').includes(skill);
        const matchSearch = !query || text.includes(query);
        const match = matchTheme && matchDifficulty && matchSkill && matchSearch;
        (item as HTMLElement).style.display = match ? '' : 'none';
      });
    }

    themeFilter?.addEventListener('change', filter);
    difficultyFilter?.addEventListener('change', filter);
    skillFilter?.addEventListener('change', filter);
    searchInput?.addEventListener('input', filter);
  </script>
</Layout>
