---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BookCard from "../../components/book/BookCard.astro";
import { getCollection } from "astro:content";

const books = await getCollection("books");
const categories = await getCollection("categories");
const skills = await getCollection("skills");

const themes = [...new Set(books.map((b) => b.data.theme))];
const difficulties = [...new Set(books.map((b) => b.data.difficulty))];
const allSkills = [...new Set(books.flatMap((b) => b.data.skills))];
---

<BaseLayout
  title="Quiet Books | Scandinavian Montessori Principles"
  description="Explore printable activity books for creative learning and independent play. Designed with Scandinavian simplicity to foster focus and wonder."
  canonical="/quiet-books"
>
  <main class="min-h-screen">
    <!-- Hero -->
    <section class="py-16 max-w-7xl mx-auto px-6 text-center">
      <h1 class="font-display text-4xl md:text-5xl font-bold text-text mb-4">Quiet Books</h1>
      <p class="text-lg text-text-muted max-w-2xl mx-auto">
        Explore printable activity books for creative learning and independent play. Designed with Scandinavian simplicity to foster focus and wonder.
      </p>
    </section>

    <!-- Filters -->
    <section class="sticky top-20 z-40 bg-white/80 backdrop-blur-md pb-8">
      <div class="max-w-7xl mx-auto px-6">
        <div class="bg-cream rounded-soft p-4 flex flex-wrap items-end gap-4 shadow-card">
          <div class="flex flex-col gap-1 flex-1 min-w-[150px]">
            <label class="text-xs text-text-muted px-1">Theme</label>
            <select id="theme-filter" class="bg-white border border-sand rounded-lg text-sm focus:ring-2 focus:ring-brand outline-none py-2 px-3">
              <option value="">All Themes</option>
              {themes.map((t) => <option value={t}>{t}</option>)}
            </select>
          </div>

          <div class="flex flex-col gap-1 flex-1 min-w-[150px]">
            <label class="text-xs text-text-muted px-1">Difficulty</label>
            <select id="difficulty-filter" class="bg-white border border-sand rounded-lg text-sm focus:ring-2 focus:ring-brand outline-none py-2 px-3">
              <option value="">Any Level</option>
              {difficulties.map((d) => <option value={d}>{d}</option>)}
            </select>
          </div>

          <div class="flex flex-col gap-1 flex-1 min-w-[150px]">
            <label class="text-xs text-text-muted px-1">Skill Focus</label>
            <select id="skill-filter" class="bg-white border border-sand rounded-lg text-sm focus:ring-2 focus:ring-brand outline-none py-2 px-3">
              <option value="">All Skills</option>
              {allSkills.map((s) => <option value={s}>{s}</option>)}
            </select>
          </div>

          <div class="flex flex-col gap-1 flex-[1.5] min-w-[200px]">
            <label class="text-xs text-text-muted px-1">Search</label>
            <div class="relative">
              <input
                id="search-input"
                type="text"
                placeholder="Search quiet books..."
                class="w-full bg-white border border-sand rounded-lg pl-10 pr-4 py-2 text-sm focus:ring-2 focus:ring-brand outline-none"
              />
              <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-text-muted">search</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Books Grid -->
    <section class="max-w-7xl mx-auto px-6 py-12">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6" id="book-grid">
        {books.map((book) => (
          <div
            class="book-item"
            data-theme={book.data.theme}
            data-difficulty={book.data.difficulty}
            data-skills={book.data.skills.join(",")}
            data-title={book.data.title}
            data-description={book.data.description || ""}
          >
            <BookCard book={book.data} />
          </div>
        ))}
      </div>
    </section>
  </main>

  <script is:inline>
    (function() {
      var themeFilter = document.getElementById('theme-filter');
      var difficultyFilter = document.getElementById('difficulty-filter');
      var skillFilter = document.getElementById('skill-filter');
      var searchInput = document.getElementById('search-input');
      var items = document.querySelectorAll('.book-item');

      function filter() {
        var theme = themeFilter?.value || '';
        var difficulty = difficultyFilter?.value || '';
        var skill = skillFilter?.value || '';
        var query = (searchInput?.value || '').toLowerCase().trim();

        items.forEach(function(item) {
          var t = item.getAttribute('data-theme') || '';
          var d = item.getAttribute('data-difficulty') || '';
          var s = item.getAttribute('data-skills') || '';
          var title = item.getAttribute('data-title') || '';
          var desc = item.getAttribute('data-description') || '';
          var text = (title + ' ' + desc).toLowerCase();
          var match = (!theme || t === theme) &&
                      (!difficulty || d === difficulty) &&
                      (!skill || s.split(',').includes(skill)) &&
                      (!query || text.indexOf(query) !== -1);
          item.style.display = match ? '' : 'none';
        });
      }

      themeFilter?.addEventListener('change', filter);
      difficultyFilter?.addEventListener('change', filter);
      skillFilter?.addEventListener('change', filter);
      searchInput?.addEventListener('input', filter);
    })();
  </script>
</BaseLayout>
