---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const blogFiles = import.meta.glob("../../content/blog/*.md", { eager: true });
const posts = Object.values(blogFiles).map((post: any) => ({
  title: post.frontmatter.title,
  slug: post.frontmatter.slug,
  description: post.frontmatter.seo_description,
  published_at: post.frontmatter.published_at,
  content: post.default,
}));

posts.sort((a, b) => new Date(b.published_at).getTime() - new Date(a.published_at).getTime());
---

<Layout
  title="Quiet Book Blog"
  description="Learn about quiet books, their benefits and how to make printable quiet books for kids."
>
  <Header />

  <main class="bg-surface pt-8 pb-20">
    <section class="container-main">
      <div class="py-12 md:py-16 text-center">
        <h1 class="font-display text-headline-lg-mobile md:text-headline-lg font-bold text-on-surface">Blog</h1>
        <p class="text-body-lg text-on-surface-variant mt-4 max-w-2xl mx-auto">
          Guides, ideas and tips about quiet books, hands-on learning and creative play.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {posts.map((post) => (
          <a
            href={`/blog/${post.slug}`}
            class="group block bg-surface-container-lowest rounded-xl soft-bloom p-6 md:p-8 border border-outline-variant/20"
          >
            <h2 class="font-display text-headline-sm font-bold text-on-surface group-hover:text-primary transition-colors">
              {post.title}
            </h2>
            <p class="text-body-md text-on-surface-variant mt-3">
              {post.description}
            </p>
            <span class="inline-block mt-4 text-body-sm text-on-surface-variant">
              {post.published_at}
            </span>
          </a>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</Layout>
