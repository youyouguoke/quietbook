---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const bookFiles = import.meta.glob("../content/books/*.md", { eager: true });
const books = Object.values(bookFiles).map((b: any) => b.frontmatter);

const categoryFiles = import.meta.glob("../content/categories/*.md", { eager: true });
const categories = Object.values(categoryFiles).map((c: any) => c.frontmatter);

const searchIndex = books.map((b) => ({
  title: b.title,
  slug: b.slug,
  theme: b.theme,
  skills: b.skills,
  difficulty: b.difficulty,
  description: b.seo_description,
  url: `/quiet-book/${b.slug}`,
}));
---

<Layout title="Search" description="Search free printable quiet books by theme, skill or keyword.">
  <Header />

  <main class="bg-surface pt-8 pb-20">
    <section class="container-main max-w-3xl">
      <div class="py-12 md:py-16 text-center">
        <h1 class="font-display text-headline-lg-mobile md:text-headline-lg font-bold text-on-surface">Search Quiet Books</h1>
        <p class="text-body-lg text-on-surface-variant mt-4">
          Find printable quiet books by theme, skill or keyword.
        </p>
      </div>

      <div class="relative">
        <input
          type="text"
          id="search-input"
          placeholder="Try dinosaur, matching, easy..."
          class="w-full px-5 py-4 rounded-xl bg-surface-container-lowest border border-outline-variant focus:border-primary outline-none text-body-md"
        />
      </div>

      <div id="search-results" class="mt-8 grid grid-cols-1 gap-4">
      </div>
    </section>
  </main>

  <Footer />

  <script define:vars={{ searchIndex }}>
    const input = document.getElementById('search-input');
    const results = document.getElementById('search-results');

    function render(query) {
      const q = query.toLowerCase().trim();
      if (!q) {
        results.innerHTML = '';
        return;
      }

      const matches = searchIndex.filter((item) => {
        const text = `${item.title} ${item.theme} ${item.skills.join(' ')} ${item.difficulty} ${item.description}`.toLowerCase();
        return text.includes(q);
      });

      if (matches.length === 0) {
        results.innerHTML = `
          <div class="p-6 text-center text-body-md text-on-surface-variant bg-surface-container-low rounded-xl">
            No books found. Try "dinosaur", "matching" or "easy".
          </div>
        `;
        return;
      }

      results.innerHTML = matches.map((item) => `
        <a href="${item.url}" class="block p-5 bg-surface-container-lowest rounded-xl border border-outline-variant/20 hover:border-primary/30 transition-colors">
          <h3 class="font-display text-headline-sm font-bold text-on-surface">${item.title}</h3>
          <p class="text-body-md text-on-surface-variant mt-1">${item.theme} · ${item.difficulty} · ${item.skills.join(', ')}</p>
        </a>
      `).join('');
    }

    input?.addEventListener('input', (e) => {
      render(e.target.value);
    });

    const params = new URLSearchParams(window.location.search);
    const initial = params.get('q') || '';
    if (initial) {
      input.value = initial;
      render(initial);
    }
  </script>
</Layout>
