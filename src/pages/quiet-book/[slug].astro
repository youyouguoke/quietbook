---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BookHero from "../../components/book/BookHero.astro";
import BookFacts from "../../components/book/BookFacts.astro";
import BookGallery from "../../components/book/BookGallery.astro";
import ActivityCard from "../../components/book/ActivityCard.astro";
import SkillList from "../../components/book/SkillList.astro";
import DownloadBox from "../../components/book/DownloadBox.astro";
import FAQ from "../../components/seo/FAQ.astro";
import BookCard from "../../components/book/BookCard.astro";
import JsonLd from "../../components/seo/JsonLd.astro";
import Breadcrumb from "../../components/common/Breadcrumb.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const books = await getCollection("books");
  return books.map((book) => ({
    params: { slug: book.data.slug },
    props: { book },
  }));
}

const { book } = Astro.props;
const data = book.data;

const allBooks = await getCollection("books");
const relatedBooks = allBooks
  .filter((b) => b.data.theme === data.theme && b.data.slug !== data.slug)
  .slice(0, 3);

const skills = [
  { name: "Science", description: "Introducing prehistoric concepts and classification systems.", icon: "science" },
  { name: "Fine Motor", description: "Precision movements through cutting, matching, and velcro manipulation.", icon: "back_hand" },
  { name: "Logic", description: "Critical thinking and patterns through sequential activity pages.", icon: "lightbulb" },
];

const materials = [
  { name: "Printer", icon: "print" },
  { name: "Heavy Paper", icon: "description" },
  { name: "Scissors", icon: "content_cut" },
  { name: "Laminator", icon: "layers", optional: true },
  { name: "Velcro Dots", icon: "radio_button_checked" },
];

const faqs = data.faqs || [
  { question: "How many pages are in the PDF?", answer: `The full adventure includes ${data.pages} printable activity pages, plus cut-out pieces where needed.` },
  { question: "Is lamination required?", answer: "While not strictly required, lamination significantly extends the life of the book and allows for the use of velcro dots, which makes the book much more tactile and durable for repeated play." },
  { question: "What age range is this suitable for?", answer: "The activities are tailored for children aged 3 to 6 years old, covering a range of simple matching to more complex sorting tasks." },
];

const activities = data.activities || [
  { name: "Dinosaur Matching", type: "Matching", difficulty: "Easy", skill: "Visual Discrimination", description: "Pair dinosaurs with their shadow silhouettes to develop visual discrimination and shape recognition." },
  { name: "Fossil Puzzle", type: "Puzzle", difficulty: "Medium", skill: "Spatial Reasoning", description: "Assemble skeletal remains to learn basic anatomy and problem-solving through spatial reasoning." },
  { name: "Dinosaur Sorting", type: "Sorting", difficulty: "Medium", skill: "Classification", description: "Categorize dinosaurs by diet or size to build foundational logic skills." },
];
---

<BaseLayout
  title={`${data.title} | Quiet Library`}
  description={data.description}
  image={data.cover}
  canonical={`/quiet-book/${data.slug}`}
>
  <Fragment slot="head">
    <JsonLd type="Book" data={data} />
    <JsonLd type="FAQPage" data={faqs} />
  </Fragment>

  <div class="max-w-7xl mx-auto px-6">
    <Breadcrumb items={[
      { label: "Library", href: "/quiet-books" },
      { label: data.title },
    ]} />
  </div>

  <!-- Hero + Facts -->
  <section class="py-12 max-w-7xl mx-auto px-6">
    <div class="grid md:grid-cols-12 gap-8 items-center">
      <div class="md:col-span-7">
        <div class="aspect-square w-full bg-cream rounded-soft overflow-hidden shadow-card">
          <img
            src={data.cover}
            alt={`${data.title} cover`}
            class="w-full h-full object-cover"
            onerror="this.src='/images/placeholder.webp'"
          />
        </div>
      </div>
      <div class="md:col-span-5 flex flex-col gap-6">
        <BookHero book={book} />
        <BookFacts book={book} />
        <DownloadBox href={data.pdf || "#"} />
      </div>
    </div>
  </section>

  <BookGallery images={data.images || ["/images/book-detail/preview1.jpg", "/images/book-detail/preview2.jpg", "/images/book-detail/preview3.jpg", "/images/book-detail/preview4.jpg"]} />

  <!-- Montessori Approach -->
  <section class="py-20 max-w-3xl mx-auto px-6 text-center">
    <h2 class="font-display text-3xl font-semibold text-text mb-8">The Montessori Approach</h2>
    <div class="space-y-6 text-text-muted text-lg">
      <p>The {data.title} is more than just a coloring activity. Inspired by Scandinavian minimalism and the Montessori "prepared environment" philosophy, every page is designed to isolate specific skills—from fine motor pincer grips to complex logical sorting.</p>
      <p>By providing children with tactile, movable parts, we transform abstract concepts into concrete, hands-on learning experiences. The muted palette ensures the child isn't overstimulated, allowing them to focus entirely on the educational task at hand.</p>
    </div>
  </section>

  <!-- Activities -->
  <section class="py-20 bg-cream">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="font-display text-3xl font-semibold text-text mb-10 text-center">Activities Included</h2>
      <ActivityCard activities={activities} />
    </div>
  </section>

  <!-- Skills Developed -->
  <section class="bg-brand text-white py-20 overflow-hidden relative">
    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <div class="text-center mb-16">
        <h2 class="font-display text-3xl font-semibold mb-4">Nurturing Growth</h2>
        <p class="text-white/80 max-w-xl mx-auto">This resource targets key developmental milestones during the early years.</p>
      </div>
      <SkillList skills={skills} />
    </div>
  </section>

  <!-- Preparation Guide -->
  <section class="py-20 max-w-7xl mx-auto px-6">
    <h2 class="font-display text-3xl font-semibold text-text mb-10 text-center">Preparation Guide</h2>
    <div class="flex flex-wrap justify-center gap-12 items-start">
      {materials.map((m) => (
        <div class="flex flex-col items-center w-32 group">
          <div class="w-20 h-20 bg-cream rounded-full flex items-center justify-center mb-4 group-hover:bg-brand-light transition-colors">
            <span class="material-symbols-outlined text-brand text-3xl">{m.icon}</span>
          </div>
          <p class="text-sm font-medium text-text">{m.name}</p>
          {m.optional && <span class="text-xs text-text-muted">Optional</span>}
        </div>
      ))}
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 bg-cream">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="font-display text-3xl font-semibold text-text mb-10 text-center">Frequently Asked Questions</h2>
      <FAQ faqs={faqs} />
    </div>
  </section>

  <!-- Related Themes -->
  <section class="py-20 max-w-7xl mx-auto px-6">
    <h2 class="font-display text-3xl font-semibold text-text mb-10">Related Themes</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {relatedBooks.length > 0 ? relatedBooks.map((b) => <BookCard book={b.data} />) : (
        <div class="col-span-3 text-center text-text-muted">
          Explore more books in the <a href="/quiet-books" class="text-brand underline">Library</a>.
        </div>
      )}
    </div>
  </section>
</BaseLayout>
