---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="About"
  description="Quiet Book Library is a free resource for parents and educators looking for printable quiet books and hands-on learning activities."
>
  <Header />

  <main class="bg-surface pt-8 pb-20">
    <section class="container-main max-w-3xl">
      <div class="py-12 md:py-16 text-center">
        <h1 class="font-display text-headline-lg-mobile md:text-headline-lg font-bold text-on-surface">About Quiet Book Library</h1>
      </div>

      <div class="prose-body text-on-surface-variant space-y-6">
        <p>
          Quiet Book Library is a collection of free printable quiet books and hands-on activities for children. We believe learning happens best when children are curious, engaged and using their hands.
        </p>

        <p>
          Every quiet book is designed with clear learning goals, beautiful illustrations and simple instructions. Parents and teachers can download the PDF, print the pages and assemble the activities in minutes.
        </p>

        <p>
          Our themes cover dinosaurs, animals, space, life skills, learning basics and more. Each book targets specific skills like fine motor control, matching, logic, creativity and early academic concepts.
        </p>

        <p>
          All resources are free for personal and classroom use. New books and guides are added regularly.
        </p>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
