---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const collections = [
  {
    title: "The Nature Series",
    description: "Explore seasonal cycles, forest animals, and botanical wonders through interactive paper puzzles.",
    image: "/images/collection-nature.jpg",
    tag: "Ages 2-4",
    span: "md:col-span-7",
    height: "h-80",
  },
  {
    title: "Daily Life Skills",
    description: "Practical life activities including zip-up puzzles and time-telling games.",
    image: "/images/collection-daily.jpg",
    span: "md:col-span-5",
    height: "h-64",
  },
];

const mathFeatures = ["Counting", "Shapes", "Logic"];

const steps = [
  {
    icon: "search",
    title: "Discover",
    description: "Browse our curated collections of age-appropriate printable activities tailored to your child's developmental milestones.",
  },
  {
    icon: "print",
    title: "Print",
    description: "Download high-resolution PDFs instantly and print them on your choice of sustainable materials or cardstock at home.",
  },
  {
    icon: "child_care",
    title: "Play",
    description: "Assemble with ease and watch your little one engage in deep, focused, and meaningful independent play sessions.",
  },
];

const stats = [
  { value: "100%", label: "Tactile" },
  { value: "Eco", label: "Printables" },
  { value: "Zero", label: "Distraction" },
  { value: "Pure", label: "Focus" },
];
---

<Layout
  title="Quiet Library | Nurturing Curious Minds"
  description="High-quality, printable educational resources inspired by Scandinavian Montessori principles. Create tactile learning environments at home."
>
  <Header />

  <main class="pb-16 md:pb-0">
    <!-- Hero Section -->
    <section class="relative overflow-hidden bg-surface py-section-gap">
      <div class="container-main grid md:grid-cols-2 gap-12 items-center">
        <div class="z-10 text-center md:text-left">
          <h1 class="font-display text-display-lg text-on-background mb-6 leading-tight">
            Nurturing <span class="text-primary">Curious Minds</span> through Quiet Play.
          </h1>
          <p class="font-body text-body-lg text-on-surface-variant mb-10 max-w-lg mx-auto md:mx-0">
            High-quality, printable educational resources inspired by Scandinavian Montessori principles. Create tactile learning environments at home.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start">
            <a href="/quiet-books" class="bg-primary text-on-primary px-8 py-4 rounded-xl font-label-md text-label-md hover:shadow-lg transition-all active:scale-95 inline-flex items-center justify-center">
              Explore the Library
            </a>
            <a href="#" class="border-2 border-primary-container text-primary px-8 py-4 rounded-xl font-label-md text-label-md hover:bg-primary-container transition-all active:scale-95 inline-flex items-center justify-center">
              Watch How-to Guide
            </a>
          </div>
        </div>

        <div class="relative group">
          <div class="absolute -inset-4 bg-tertiary-fixed-dim/30 rounded-[40px] blur-3xl group-hover:bg-primary-fixed/20 transition-colors duration-700"></div>
          <img
            src="/images/hero.jpg"
            alt="A serene photograph of a toddler engaged in a felt quiet book"
            class="relative z-10 w-full aspect-[4/5] object-cover rounded-3xl soft-bloom"
          />
        </div>
      </div>
    </section>

    <!-- How it Works -->
    <section id="how-it-works" class="bg-surface-container-low py-section-gap">
      <div class="container-main">
        <div class="text-center mb-16">
          <h2 class="font-display text-headline-lg text-on-surface mb-4">A Simple Path to Focus</h2>
          <div class="w-20 h-1 bg-primary-container mx-auto rounded-full"></div>
        </div>

        <div class="grid md:grid-cols-3 gap-gutter">
          {steps.map((step) => (
            <div class="bg-surface-container-lowest p-8 rounded-2xl soft-bloom hover-lift transition-all flex flex-col items-center text-center">
              <div class="w-16 h-16 bg-surface-container-high rounded-full flex items-center justify-center mb-6 text-primary">
                <span class="material-symbols-outlined text-4xl">{step.icon}</span>
              </div>
              <h3 class="font-display text-headline-md mb-3">{step.title}</h3>
              <p class="font-body text-body-md text-on-surface-variant">
                {step.description}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Featured Collections - Asymmetric Grid -->
    <section class="py-section-gap bg-surface">
      <div class="container-main">
        <div class="flex justify-between items-end mb-12">
          <div>
            <h2 class="font-display text-headline-lg text-on-surface mb-2">Featured Collections</h2>
            <p class="font-body text-body-md text-on-surface-variant">The best of our prepared environments.</p>
          </div>
          <a href="/quiet-books" class="text-primary font-semibold flex items-center gap-1 hover:underline">
            View All <span class="material-symbols-outlined">chevron_right</span>
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-12 gap-gutter">
          {collections.map((c) => (
            <div class:list={[c.span, "bg-surface-container-lowest rounded-3xl overflow-hidden soft-bloom hover-lift transition-all group flex flex-col"]} id={c.title}>
              <div class:list={[c.height, "relative overflow-hidden"]} id="image">
                <img
                  src={c.image}
                  alt={c.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                />
                {c.tag && (
                  <div class="absolute top-4 left-4">
                    <span class="bg-secondary-container text-on-secondary-container px-3 py-1 rounded-full text-label-sm font-label-sm uppercase tracking-wider">
                      {c.tag}
                    </span>
                  </div>
                )}
              </div>
              <div class="p-8 flex-grow">
                <h3 class="font-display text-headline-md mb-2">{c.title}</h3>
                <p class="font-body text-body-md text-on-surface-variant mb-6">{c.description}</p>
                <a href="/quiet-books" class="text-primary font-semibold flex items-center gap-2">
                  {c.title === "The Nature Series" ? "View Collection" : "Explore"} 
                  <span class="material-symbols-outlined">arrow_forward</span>
                </a>
              </div>
            </div>
          ))}

          <!-- Little Mathematician -->
          <div class="md:col-span-12 bg-primary-container/10 rounded-3xl overflow-hidden p-8 flex flex-col md:flex-row items-center gap-8 soft-bloom">
            <div class="w-full md:w-1/2 h-64 md:h-auto rounded-2xl overflow-hidden">
              <img
                src="/images/collection-math.jpg"
                alt="Little Mathematician"
                class="w-full h-full object-cover"
              />
            </div>
            <div class="w-full md:w-1/2 text-center md:text-left">
              <h3 class="font-display text-headline-md mb-2">Little Mathematician</h3>
              <p class="font-body text-body-md text-on-surface-variant mb-6">
                Foundational numeracy built through tactile association and geometric shape discovery. Perfect for early educators and homeschoolers.
              </p>
              <div class="flex flex-wrap gap-2 justify-center md:justify-start mb-6">
                {mathFeatures.map((feature) => (
                  <span class="px-4 py-1 bg-secondary/10 text-secondary rounded-full font-label-sm text-label-sm">
                    {feature}
                  </span>
                ))}
              </div>
              <a href="/quiet-books" class="bg-primary text-on-primary px-6 py-3 rounded-xl font-label-md text-label-md active:scale-95 transition-all inline-flex items-center justify-center">
                Shop Collection
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Montessori Blurb -->
    <section class="py-section-gap relative overflow-hidden">
      <div class="absolute inset-0 bg-tertiary-fixed opacity-20 pointer-events-none"></div>
      <div class="container-main relative z-10 text-center">
        <div class="max-w-3xl mx-auto">
          <span class="material-symbols-outlined text-secondary text-5xl mb-6">auto_awesome</span>
          <h2 class="font-display text-headline-lg md:text-display-lg text-on-surface mb-8">The Philosophy of Quiet</h2>
          <p class="font-body text-body-lg text-on-surface-variant leading-relaxed mb-10">
            At Quiet Library, we believe that children thrive in a "prepared environment"—a space designed with intentionality, beauty, and order. Inspired by the Montessori approach, our resources eliminate the overstimulation of modern toys, replacing them with focused, hands-on tasks that build confidence, autonomy, and fine motor skills.
          </p>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
            {stats.map((stat) => (
              <div class="flex flex-col items-center">
                <span class="font-display text-headline-md text-primary">{stat.value}</span>
                <span class="font-label-sm text-label-sm text-on-surface-variant">{stat.label}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
