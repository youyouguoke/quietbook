---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSection from "../components/HeroSection.astro";
import ThemeCard from "../components/category/ThemeCard.astro";
import BookGrid from "../components/book/BookGrid.astro";
import FAQ from "../components/seo/FAQ.astro";
import JsonLd from "../components/seo/JsonLd.astro";
import { getCollection } from "astro:content";

const books = await getCollection("books");
const featuredBooks = books.slice(0, 4);
const categories = await getCollection("categories");
const skills = await getCollection("skills");

const faqs = [
  { question: "What is a quiet book?", answer: "A quiet book is a soft, interactive book designed for children that includes educational activities like matching, sorting, zipping, and buttoning." },
  { question: "Are your quiet books free?", answer: "Yes. Every book in the Quiet Library is available as a free PDF download for parents and educators." },
  { question: "How do I assemble the book?", answer: "Print the PDF on heavy paper, laminate the pages for durability, and attach velcro dots to the movable pieces." },
];

const pageJsonLd = [
  { type: "WebPage", data: { title: "Quiet Library", description: "Nurturing Curious Minds through Quiet Play", url: "/" } },
  { type: "ItemList", data: featuredBooks.map((b) => b.data) },
  { type: "FAQPage", data: faqs },
];
---

<BaseLayout
  title="Quiet Library | Nurturing Curious Minds"
  description="Discover free printable quiet books and Montessori-inspired activities for focused, independent play."
  image="/images/hero.jpg"
  canonical="/"
>
  <!-- JSON-LD -->
  <Fragment slot="head">
    {pageJsonLd.map((ld) => (
      <JsonLd type={ld.type} data={ld.data} />
    ))}
  </Fragment>

  <HeroSection
    title="Nurturing Curious Minds through Quiet Play."
    subtitle="Beautiful printable quiet books inspired by Montessori and Scandinavian design. Print, assemble, and play at home or in the classroom."
    image="/images/hero.jpg"
    primaryCta={{ label: "Explore the Library", href: "/quiet-books" }}
    secondaryCta={{ label: "Watch How-to Guide", href: "#how-it-works" }}
  />

  <!-- How it Works -->
  <section id="how-it-works" class="py-20 bg-cream">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="font-display text-3xl font-semibold text-text mb-3">A Simple Path to Focus</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center">
          <span class="material-symbols-outlined text-5xl text-brand mb-4">search</span>
          <h3 class="font-display text-xl font-semibold text-text mb-2">Discover</h3>
          <p class="text-text-muted">Browse themed quiet books by age, skill, or learning goal.</p>
        </div>
        <div class="text-center">
          <span class="material-symbols-outlined text-5xl text-brand mb-4">print</span>
          <h3 class="font-display text-xl font-semibold text-text mb-2">Print</h3>
          <p class="text-text-muted">Download the free PDF and print on heavy paper at home.</p>
        </div>
        <div class="text-center">
          <span class="material-symbols-outlined text-5xl text-brand mb-4">child_care</span>
          <h3 class="font-display text-xl font-semibold text-text mb-2">Play</h3>
          <p class="text-text-muted">Watch your child build focus and independence through hands-on play.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Collections -->
  <section class="py-20 max-w-7xl mx-auto px-6">
    <div class="flex justify-between items-end mb-10">
      <div>
        <h2 class="font-display text-3xl font-semibold text-text mb-2">Featured Collections</h2>
        <p class="text-text-muted">Curated themes to spark wonder and independent learning.</p>
      </div>
      <a href="/categories" class="text-brand font-medium hover:underline">View All →</a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="relative rounded-soft overflow-hidden bg-cream aspect-[4/3] group">
        <img src="/images/collection-nature.jpg" alt="Nature Series" class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent flex flex-col justify-end p-8">
          <h3 class="font-display text-2xl font-semibold text-white mb-1">The Nature Series</h3>
          <a href="/categories" class="text-white/90 hover:text-white">View Collection →</a>
        </div>
      </div>
      <div class="relative rounded-soft overflow-hidden bg-cream aspect-[4/3] group">
        <img src="/images/collection-daily.jpg" alt="Daily Life Skills" class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent flex flex-col justify-end p-8">
          <h3 class="font-display text-2xl font-semibold text-white mb-1">Daily Life Skills</h3>
          <a href="/categories" class="text-white/90 hover:text-white">Explore →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Books -->
  <section class="py-20 bg-cream">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex justify-between items-end mb-10">
        <div>
          <h2 class="font-display text-3xl font-semibold text-text mb-2">Featured Books</h2>
          <p class="text-text-muted">Hand-picked favorites from the library.</p>
        </div>
        <a href="/quiet-books" class="text-brand font-medium hover:underline">View All →</a>
      </div>

      <BookGrid books={featuredBooks} />
    </div>
  </section>

  <!-- Philosophy -->
  <section class="py-20 max-w-7xl mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div class="aspect-[4/3] rounded-soft overflow-hidden bg-cream">
        <img src="/images/collection-math.jpg" alt="Philosophy of Quiet" class="w-full h-full object-cover" />
      </div>
      <div class="space-y-6">
        <h2 class="font-display text-3xl font-semibold text-text">The Philosophy of Quiet</h2>
        <p class="text-text-muted leading-relaxed">
          Our quiet books are rooted in Montessori principles: child-led activity, hands-on engagement, and calm, focused learning. Each page is designed to build independence while respecting a child's natural rhythm.
        </p>
        <div class="grid grid-cols-2 gap-4">
          {skills.slice(0, 4).map((skill) => (
            <div class="bg-cream rounded-soft p-4">
              <h4 class="font-display font-semibold text-text">{skill.data.name}</h4>
              <p class="text-sm text-text-muted">{skill.data.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 bg-cream">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="font-display text-3xl font-semibold text-text mb-10 text-center">Frequently Asked Questions</h2>
      <FAQ faqs={faqs} />
    </div>
  </section>
</BaseLayout>
